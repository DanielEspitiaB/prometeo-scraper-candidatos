# Copia este archivo a .streamlit/secrets.toml y completa los valores.
# NUNCA subas secrets.toml al repo (ya esta en .gitignore).
# En Streamlit Community Cloud, estos valores van en el gestor de secrets, no en el codigo.
#
# Aun no se usan en este esqueleto. Se necesitan a partir del siguiente paso:

APIFY_TOKEN = "tu_token_de_apify_aqui"
ANTHROPIC_API_KEY = "tu_api_key_de_anthropic_aqui"
